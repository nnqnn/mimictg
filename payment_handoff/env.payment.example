# Minimal payment-related environment for the target project.
# Replace only placeholders; do not copy secrets from the source project's .env.

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB_NAME
TIMEZONE=Europe/Moscow

# TelegaPay
TELEGAPAY_BASE_URL=https://secure.telegapay.link/api/v1
TELEGAPAY_API_KEY=NEW_PROJECT_API_KEY
TELEGAPAY_RETURN_URL=https://t.me/your_new_bot

# Payment lifecycle
PAYMENT_MIN_AMOUNT=100
PAYMENT_TTL_MINUTES=60
PAYMENT_POLL_INTERVAL_SECONDS=60

# Billing defaults used by the copied BillingService
MONTH_PRICE_RUB=100

# Optional notifications/logging used by the source implementation
SUPER_ADMIN_ID=123456789
LOG_LEVEL=INFO
LOG_DIR=./logs
